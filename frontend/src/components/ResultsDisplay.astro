<!-- Results Display -->
<div id="results-wrapper">
  <!-- Empty State -->
  <div class="empty-state visible" id="empty-state">
    <div class="empty-icon">✨</div>
    <h3 data-i18n="emptyTitle">等待灵感碎片</h3>
    <p data-i18n="emptyDesc">在左侧输入您的行业和核心关键词，
AI 品牌大师将为您探索最优质的商标方案。</p>
  </div>

  <!-- Thinking -->
  <div class="thinking-box" id="thinking-container" style="display:none">
    <div class="thinking-header" id="thinking-header">
      <div class="spinner" id="thinking-spinner"></div>
      <span id="thinking-status-text" data-i18n="thinkingStatus">AI 正在思考中...</span>
      <button class="toggle-btn hidden" id="thinking-toggle-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>
    <div class="thinking-content" id="thinking-content"></div>
  </div>

  <!-- Error -->
  <div class="error-box" id="error-container"></div>

  <!-- Results -->
  <div class="results-container" id="results-container">
    <hr class="divider" />
    <h3 class="results-title" data-i18n="resultsTitle">生成结果</h3>
    <div id="results-list"></div>
  </div>
</div>

<style>
  /* Empty State */
  .empty-state {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    text-align: center;
    opacity: 0;
    transition: opacity 0.4s;
  }
  .empty-state.visible { display: flex; opacity: 1; }
  .empty-icon { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.7; }
  .empty-state h3 { font-size: 16px; font-weight: 600; color: var(--text-main); margin-bottom: 6px; }
  .empty-state p { font-size: 13px; color: var(--text-muted); line-height: 1.6; white-space: pre-line; max-width: 280px; }

  /* Thinking */
  .thinking-box {
    background: var(--thinking-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 12px;
    display: none;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .thinking-box.visible { display: block; opacity: 1; }
  .thinking-header {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--primary);
    cursor: pointer;
    user-select: none;
  }
  .thinking-header .spinner { display: block; width: 12px; height: 12px; border-width: 1.5px; border-color: var(--border); border-top-color: var(--primary); }
  .thinking-header .spinner.hidden { display: none; }
  .thinking-header.completed { color: var(--success); }
  .thinking-header.completed .spinner { display: none; }

  .toggle-btn {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 2px;
    display: flex;
    transition: transform 0.2s;
  }
  .toggle-btn.hidden { display: none; }
  .thinking-header.collapsed .toggle-btn svg { transform: rotate(180deg); }

  .thinking-content {
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: var(--text-muted);
    line-height: 1.6;
    white-space: pre-wrap;
    max-height: 180px;
    overflow-y: auto;
    margin-top: 6px;
  }
  .thinking-header.collapsed + .thinking-content { max-height: 0; overflow: hidden; margin-top: 0; }

  .thinking-content::-webkit-scrollbar { width: 3px; }
  .thinking-content::-webkit-scrollbar-track { background: transparent; }
  .thinking-content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

  /* Error */
  .error-box {
    display: none;
    margin-top: 12px;
    padding: 10px 12px;
    background: var(--danger-bg);
    border: 1px solid var(--danger-border);
    border-radius: var(--radius-sm);
    color: var(--danger);
    font-size: 13px;
  }

  /* Results */
  .results-container {
    opacity: 0;
    transform: translateY(6px);
    transition: all 0.4s ease;
  }
  .results-container.visible { opacity: 1; transform: none; }
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 20px 0;
  }
  .results-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 12px;
  }
</style>
