<!-- Generator Form -->
<form id="generator-form">
  <div class="form-group">
    <label for="industry" data-i18n="industryLabel">所属行业</label>
    <input type="text" id="industry" required placeholder="例如：新能源汽车" data-i18n-placeholder="industryPlaceholder" />
  </div>
  <div class="form-group">
    <label for="keywords" data-i18n="keywordsLabel">核心关键词 (顿号或空格隔开)</label>
    <input type="text" id="keywords" required placeholder="例如：智能、安全、未来" data-i18n-placeholder="keywordsPlaceholder" />
  </div>
  <button type="submit" id="submit-btn">
    <span class="btn-text" data-i18n="submitBtn">立即生成</span>
    <div class="spinner" id="submit-spinner"></div>
  </button>
</form>

<style>
  form {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .form-group {
    margin-bottom: 12px;
  }
  label {
    display: block;
    margin-bottom: 4px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  input {
    width: 100%;
    padding: 8px 10px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-main);
    font-size: 13px;
    font-family: var(--font-sans);
    outline: none;
    transition: all var(--transition);
  }
  input::placeholder { color: var(--text-faint); }
  input:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px var(--primary-light);
  }
  button {
    width: 100%;
    padding: 8px;
    margin-top: auto;
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    position: relative;
  }
  button:hover:not(:disabled) {
    background: var(--primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
  }
  button:active:not(:disabled) { transform: none; }
  button:disabled { opacity: 0.6; cursor: not-allowed; }
  button.loading .btn-text { opacity: 0; }
  button.loading .spinner { display: block; position: absolute; }
</style>
