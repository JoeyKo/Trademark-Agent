---
import Layout from "../layouts/Layout.astro";
import GeneratorForm from "../components/GeneratorForm.astro";
import ResultsDisplay from "../components/ResultsDisplay.astro";
---

<Layout title="AI商标起名">
	<!-- ========== Header ========== -->
	<header class="header">
		<div class="header-title" data-i18n="logo">✦ AI商标起名</div>
		<div class="header-actions">
			<button class="header-btn" id="lang-toggle" title="切换语言">
				<span id="lang-label">EN</span>
			</button>
			<button class="header-btn" id="theme-toggle" title="切换主题">
				<svg id="icon-sun" class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
				<svg id="icon-moon" class="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
			</button>
		</div>
	</header>

	<!-- ========== Content ========== -->
	<div class="content">
		<!-- Left: Prompt Panel -->
		<aside class="panel-left">
			<div class="panel-section">
				<h3 class="panel-title" data-i18n="sidebarTitle">输入信息</h3>
				<p class="panel-desc" data-i18n="sidebarDesc">填写行业和关键词，AI 将为您生成优质商标方案</p>
			</div>
			<GeneratorForm />
		</aside>

		<!-- Right: Results Area -->
		<main class="panel-right">
			<ResultsDisplay />
		</main>
	</div>

	<script>
		// ==================== i18n ====================
		const i18n: Record<string, Record<string, string>> = {
			zh: {
				logo: "✦ AI商标起名",
				sidebarTitle: "输入信息",
				sidebarDesc: "填写行业和关键词，AI 将为您生成优质商标方案",
				industryLabel: "所属行业",
				industryPlaceholder: "例如：新能源汽车",
				keywordsLabel: "核心关键词 (顿号或空格隔开)",
				keywordsPlaceholder: "例如：智能、安全、未来",
				submitBtn: "立即生成",
				emptyTitle: "等待灵感碎片",
				emptyDesc: "在左侧输入您的行业和核心关键词，\nAI 品牌大师将为您探索最优质的商标方案。",
				thinkingStatus: "AI 正在思考中...",
				thinkingDone: "思考完成",
				resultsTitle: "生成结果",
				statusPass: "可用方案",
				statusFail: "风险标记",
				searchLink: "阿里云查重",
				errorNoResult: "未能生成有效的商标名称，请换个更常见的关键词重试。",
				errorNetwork: "网络请求失败。请确保后台服务正在运行。",
				errorRequest: "请求失败",
			},
			en: {
				logo: "✦ AI Trademark Naming",
				sidebarTitle: "Input",
				sidebarDesc: "Enter your industry and keywords, AI will generate quality brand names",
				industryLabel: "Industry",
				industryPlaceholder: "e.g. New Energy Vehicles",
				keywordsLabel: "Keywords (comma or space separated)",
				keywordsPlaceholder: "e.g. intelligent, safe, future",
				submitBtn: "Generate",
				emptyTitle: "Waiting for Inspiration",
				emptyDesc: "Enter your industry and keywords on the left,\nAI will explore the best trademark options for you.",
				thinkingStatus: "AI is thinking...",
				thinkingDone: "Thinking complete",
				resultsTitle: "Results",
				statusPass: "Available",
				statusFail: "Risk",
				searchLink: "Trademark Search",
				errorNoResult: "Failed to generate valid names. Please try different keywords.",
				errorNetwork: "Network error. Please make sure the backend is running.",
				errorRequest: "Request failed",
			},
		};

		let currentLang = "zh";

		function setLang(lang: string) {
			currentLang = lang;
			localStorage.setItem("lang", lang);
			document.getElementById("lang-label")!.textContent = lang === "zh" ? "EN" : "中";
			document.querySelectorAll("[data-i18n]").forEach((el) => {
				const key = el.getAttribute("data-i18n")!;
				if (i18n[lang][key]) el.textContent = i18n[lang][key];
			});
			document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
				const key = el.getAttribute("data-i18n-placeholder")!;
				if (i18n[lang][key]) (el as HTMLInputElement).placeholder = i18n[lang][key];
			});
			document.documentElement.lang = lang === "zh" ? "zh-CN" : "en";
		}

		// ==================== Theme ====================
		function setTheme(theme: string) {
			document.documentElement.setAttribute("data-theme", theme);
			localStorage.setItem("theme", theme);
			document.getElementById("icon-sun")!.style.display = theme === "dark" ? "none" : "block";
			document.getElementById("icon-moon")!.style.display = theme === "dark" ? "block" : "none";
		}

		// ==================== Interfaces ====================
		interface CandidateScores {
			brand_recognition?: number;
			cultural_depth?: number;
			industry_fit?: number;
			registrability?: number;
		}
		interface Candidate {
			name: string;
			status: string;
			reason: string;
			strategy?: string;
			slogan?: string;
			scores?: CandidateScores;
			total_score?: number;
			query_url: string;
		}

		// ==================== Init ====================
		document.addEventListener("DOMContentLoaded", () => {
			setTheme(document.documentElement.getAttribute("data-theme") || "light");
			setLang(localStorage.getItem("lang") || "zh");

			document.getElementById("theme-toggle")!.addEventListener("click", () => {
				const cur = document.documentElement.getAttribute("data-theme");
				setTheme(cur === "dark" ? "light" : "dark");
			});
			document.getElementById("lang-toggle")!.addEventListener("click", () => {
				setLang(currentLang === "zh" ? "en" : "zh");
			});

			// Form
			const form = document.getElementById("generator-form") as HTMLFormElement;
			const industryInput = document.getElementById("industry") as HTMLInputElement;
			const keywordsInput = document.getElementById("keywords") as HTMLInputElement;
			const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
			const resultsContainer = document.getElementById("results-container") as HTMLDivElement;
			const resultsList = document.getElementById("results-list") as HTMLDivElement;
			const errorContainer = document.getElementById("error-container") as HTMLDivElement;
			const emptyState = document.getElementById("empty-state") as HTMLDivElement;
			const thinkingContainer = document.getElementById("thinking-container") as HTMLDivElement;
			const thinkingContent = document.getElementById("thinking-content") as HTMLDivElement;
			const thinkingHeader = document.getElementById("thinking-header") as HTMLDivElement;
			const thinkingSpinner = document.getElementById("thinking-spinner") as HTMLDivElement;
			const thinkingStatusText = document.getElementById("thinking-status-text") as HTMLSpanElement;
			const thinkingToggleBtn = document.getElementById("thinking-toggle-btn") as HTMLButtonElement;

			thinkingHeader.addEventListener("click", () => thinkingHeader.classList.toggle("collapsed"));

			const isLocal = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1";
			const API_URL = isLocal ? "http://127.0.0.1:8000/api/v1/generate-names-stream" : "/api/v1/generate-names-stream";

			form.addEventListener("submit", async (e: Event) => {
				e.preventDefault();
				const industry = industryInput.value;
				const keywords = keywordsInput.value;

				errorContainer.style.display = "none";
				resultsList.innerHTML = "";
				resultsContainer.classList.remove("visible");
				emptyState.classList.remove("visible");
				emptyState.style.display = "none";

				thinkingContent.textContent = "";
				thinkingHeader.classList.remove("collapsed", "completed");
				thinkingSpinner.classList.remove("hidden");
				thinkingToggleBtn.classList.add("hidden");
				thinkingStatusText.textContent = i18n[currentLang].thinkingStatus;
				thinkingContainer.classList.add("visible");
				thinkingContainer.style.display = "block";

				submitBtn.disabled = true;
				submitBtn.classList.add("loading");

				const markDone = () => {
					thinkingHeader.classList.add("completed");
					thinkingSpinner.classList.add("hidden");
					thinkingToggleBtn.classList.remove("hidden");
					thinkingStatusText.textContent = i18n[currentLang].thinkingDone;
				};

				try {
					const res = await fetch(API_URL, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({ industry, keywords }),
					});
					if (!res.ok) throw new Error(`${i18n[currentLang].errorRequest} (${res.status})`);
					if (!res.body) throw new Error("ReadableStream not supported");

					const reader = res.body.getReader();
					const decoder = new TextDecoder();
					let buffer = "";

					while (true) {
						const { done, value } = await reader.read();
						if (done) break;
						buffer += decoder.decode(value, { stream: true });
						const lines = buffer.split("\n\n");
						buffer = lines.pop() || "";

						for (const line of lines) {
							if (!line.startsWith("data: ")) continue;
							try {
								const data = JSON.parse(line.slice(6));
								if (data.type === "status") {
									thinkingStatusText.textContent = data.content;
								} else if (data.type === "reasoning") {
									thinkingContent.textContent += data.content;
									if (!thinkingHeader.classList.contains("collapsed")) {
										thinkingContent.scrollTop = thinkingContent.scrollHeight;
									}
								} else if (data.type === "result") {
									markDone();
									if (data.error_msg) showError(data.error_msg);
									if (data.candidates?.length > 0) {
										renderResults(data.candidates);
										resultsContainer.classList.add("visible");
									} else {
										showError(i18n[currentLang].errorNoResult);
									}
								} else if (data.type === "error") {
									markDone();
									showError(data.message);
								}
							} catch {}
						}
					}
				} catch (err: unknown) {
					const msg = err instanceof Error ? err.message : String(err);
					markDone();
					showError(msg === "Failed to fetch" ? i18n[currentLang].errorNetwork : msg);
				} finally {
					submitBtn.disabled = false;
					submitBtn.classList.remove("loading");
				}
			});

			function renderResults(candidates: Candidate[]) {
				const t = i18n[currentLang];
				candidates.forEach((c, i) => {
					const card = document.createElement("div");
					card.className = "result-card";
					card.style.animationDelay = `${i * 0.1}s`;

					const badge = c.status === "pass"
						? `<span class="badge badge-pass">${t.statusPass}</span>`
						: `<span class="badge badge-fail">${t.statusFail}</span>`;
					const strategy = c.strategy ? `<span class="badge badge-strategy">${c.strategy}</span>` : "";
					const score = c.total_score
						? `<span class="score-pill">${c.total_score.toFixed(1)}</span>
						   ${c.scores ? `<div class="score-dims">
						     <span>辨识${c.scores.brand_recognition||"-"}</span>
						     <span>文化${c.scores.cultural_depth||"-"}</span>
						     <span>行业${c.scores.industry_fit||"-"}</span>
						     <span>注册${c.scores.registrability||"-"}</span>
						   </div>` : ""}`
						: "";
					const slogan = c.slogan ? `<div class="slogan">「${c.slogan}」</div>` : "";

					card.innerHTML = `
						<div class="card-top">
							<div class="card-name">${c.name} ${badge} ${strategy}</div>
							<div class="card-score">${score}</div>
						</div>
						<p class="card-reason">${c.reason || ""}</p>
						${slogan}
						<div class="card-actions">
							<a href="${c.query_url}" target="_blank" rel="noopener" class="link-btn">
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
								${t.searchLink}
							</a>
						</div>`;
					resultsList.appendChild(card);
				});
			}

			function showError(msg: string) {
				errorContainer.textContent = msg;
				errorContainer.style.display = "block";
			}
		});
	</script>

	<style is:global>
		/* ========== Header ========== */
		.header {
			height: 48px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 0 20px;
			border-bottom: 1px solid var(--border);
			background: var(--bg-sidebar);
			flex-shrink: 0;
		}
		.header-title {
			font-size: 15px;
			font-weight: 700;
			color: var(--text-main);
		}
		.header-actions {
			display: flex;
			gap: 4px;
		}
		.header-btn {
			width: 32px;
			height: 32px;
			display: flex;
			align-items: center;
			justify-content: center;
			border: 1px solid var(--border);
			border-radius: var(--radius-sm);
			background: transparent;
			color: var(--text-muted);
			cursor: pointer;
			font-size: 12px;
			font-weight: 600;
			font-family: var(--font-sans);
			transition: all var(--transition);
		}
		.header-btn:hover {
			background: var(--surface-hover);
			color: var(--text-main);
		}
		.theme-icon { display: block; }

		/* ========== Content Layout ========== */
		.content {
			display: flex;
			height: calc(100vh - 48px);
			overflow: hidden;
		}

		/* ========== Left Panel ========== */
		.panel-left {
			width: 280px;
			flex-shrink: 0;
			background: var(--bg-sidebar);
			border-right: 1px solid var(--border);
			padding: 20px;
			display: flex;
			flex-direction: column;
			overflow-y: auto;
		}
		.panel-section {
			margin-bottom: 16px;
		}
		.panel-title {
			font-size: 14px;
			font-weight: 600;
			color: var(--text-main);
			margin-bottom: 4px;
		}
		.panel-desc {
			font-size: 12px;
			color: var(--text-muted);
			line-height: 1.5;
		}

		/* ========== Right Panel ========== */
		.panel-right {
			flex: 1;
			overflow-y: auto;
			padding: 24px 32px;
		}

		/* ========== Result Cards ========== */
		.result-card {
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: var(--radius-md);
			padding: 16px;
			margin-bottom: 10px;
			animation: fadeUp 0.4s ease forwards;
			opacity: 0;
			display: flex;
			flex-direction: column;
			gap: 8px;
			transition: border-color var(--transition), box-shadow var(--transition);
		}
		.result-card:hover {
			border-color: var(--primary-border);
			box-shadow: var(--shadow-md);
		}
		@keyframes fadeUp {
			from { opacity: 0; transform: translateY(10px); }
			to { opacity: 1; transform: translateY(0); }
		}

		.card-top {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 8px;
		}
		.card-name {
			font-size: 18px;
			font-weight: 700;
			color: var(--text-main);
			display: flex;
			align-items: center;
			gap: 6px;
			flex-wrap: wrap;
		}
		.card-score {
			display: flex;
			align-items: center;
			gap: 6px;
			flex-shrink: 0;
		}
		.card-reason {
			font-size: 13px;
			color: var(--text-secondary);
			line-height: 1.6;
		}

		/* Badges */
		.badge {
			font-size: 11px;
			padding: 2px 8px;
			border-radius: 99px;
			font-weight: 600;
			white-space: nowrap;
		}
		.badge-pass {
			background: var(--success-bg);
			color: var(--success);
			border: 1px solid var(--success-border);
		}
		.badge-fail {
			background: var(--danger-bg);
			color: var(--danger);
			border: 1px solid var(--danger-border);
		}
		.badge-strategy {
			background: var(--primary-light);
			color: var(--primary);
			border: 1px solid var(--primary-border);
		}

		/* Scores */
		.score-pill {
			font-size: 14px;
			font-weight: 700;
			padding: 3px 10px;
			border-radius: var(--radius-sm);
			background: var(--score-bg);
			color: var(--score-color);
		}
		.score-dims {
			display: flex;
			gap: 4px;
		}
		.score-dims span {
			font-size: 10px;
			padding: 1px 5px;
			border-radius: 4px;
			background: var(--surface-hover);
			color: var(--text-muted);
		}

		/* Slogan */
		.slogan {
			font-size: 13px;
			color: var(--slogan-color);
			font-style: italic;
			padding: 6px 10px;
			background: var(--slogan-bg);
			border-left: 2px solid var(--slogan-border);
			border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
		}

		/* Actions */
		.card-actions {
			display: flex;
			justify-content: flex-end;
		}
		.link-btn {
			display: inline-flex;
			align-items: center;
			gap: 4px;
			font-size: 12px;
			padding: 4px 10px;
			color: var(--text-muted);
			text-decoration: none;
			border: 1px solid var(--border);
			border-radius: var(--radius-sm);
			transition: all var(--transition);
		}
		.link-btn:hover {
			color: var(--primary);
			border-color: var(--primary-border);
			background: var(--primary-light);
		}

		/* ========== Responsive ========== */
		@media (max-width: 768px) {
			.content { flex-direction: column; height: auto; }
			.panel-left { width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
			.panel-right { padding: 16px; }
			body { overflow: auto; }
		}
	</style>
</Layout>
